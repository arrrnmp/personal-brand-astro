---
interface Props {
	class?: string;
}
const { class: className = '' } = Astro.props;
---

<!--
  Isometric wireframe cube — architectural grid / 3D blueprint aesthetic
  ViewBox: 300×400 (3:4 ratio matches hero image slot)

  Cube vertices:
    A = (150,  95)  — top apex
    B = (250, 145)  — right  [A + (100, 50)]
    C = (150, 195)  — front  [A + (0, 100)]
    D = ( 50, 145)  — left   [A + (-100, 50)]
    E = (250, 245)  — right bottom  [B + (0, 100)]
    F = (150, 295)  — front bottom  [C + (0, 100)]  ← orange
    G = ( 50, 245)  — left bottom   [D + (0, 100)]
-->
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 300 400"
  class={className}
  role="img"
  aria-label="Abstract isometric wireframe geometric art"
>
  <defs>
    <pattern id="hero-dots" width="20" height="20" patternUnits="userSpaceOnUse">
      <circle cx="0"  cy="0"  r="0.7" fill="rgba(0,0,0,0.09)"/>
      <circle cx="20" cy="0"  r="0.7" fill="rgba(0,0,0,0.09)"/>
      <circle cx="0"  cy="20" r="0.7" fill="rgba(0,0,0,0.09)"/>
      <circle cx="20" cy="20" r="0.7" fill="rgba(0,0,0,0.09)"/>
    </pattern>
  </defs>

  <style>
    @keyframes draw-on {
      to { stroke-dashoffset: 0; }
    }
    @keyframes svg-fade-in {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes pop-in {
      from { opacity: 0; transform: scale(0.4); }
      to   { opacity: 1; transform: scale(1); }
    }

    /* Cube body draws in */
    .cube-top  {
      stroke-dasharray: 500; stroke-dashoffset: 500;
      animation: draw-on 1.6s cubic-bezier(0.22, 1, 0.36, 1) 0.4s forwards;
    }
    .cube-vert {
      stroke-dasharray: 200; stroke-dashoffset: 200;
      animation: draw-on 1.0s cubic-bezier(0.22, 1, 0.36, 1) 0.9s forwards;
    }
    .cube-base {
      stroke-dasharray: 200; stroke-dashoffset: 200;
      animation: draw-on 0.9s cubic-bezier(0.22, 1, 0.36, 1) 1.2s forwards;
    }

    /* Orange front edge draws on last */
    .orange-edge {
      stroke-dasharray: 100; stroke-dashoffset: 100;
      animation: draw-on 0.8s cubic-bezier(0.22, 1, 0.36, 1) 1.5s forwards;
    }

    /* Orange accent dots pop in */
    .orange-dot {
      opacity: 0;
      transform-origin: center;
      animation: pop-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 2.1s forwards;
    }
    .orange-ring {
      opacity: 0;
      transform-origin: center;
      animation: pop-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 2.3s forwards;
    }

    /* Static elements fade in early */
    .svg-static {
      animation: svg-fade-in 0.6s ease 0.2s both;
    }

    @media (prefers-reduced-motion: reduce) {
      .cube-top, .cube-vert, .cube-base { stroke-dashoffset: 0; animation: none; }
      .orange-edge { stroke-dashoffset: 0; animation: none; }
      .orange-dot, .orange-ring { opacity: 1; animation: none; }
      .svg-static { animation: none; }
    }
  </style>

  <!-- Background -->
  <rect width="300" height="400" fill="#ffffff" class="svg-static"/>
  <rect width="300" height="400" fill="url(#hero-dots)" class="svg-static"/>

  <!-- Reference circles -->
  <circle cx="150" cy="145" r="128" fill="none" stroke="rgba(17,17,17,0.045)" stroke-width="0.75" class="svg-static"/>
  <circle cx="150" cy="145" r="88"  fill="none" stroke="rgba(17,17,17,0.04)"  stroke-width="0.75" class="svg-static"/>

  <!-- Isometric ellipse inscribed in top face -->
  <ellipse cx="150" cy="145" rx="50" ry="25"
    fill="none" stroke="rgba(17,17,17,0.22)" stroke-width="0.75" stroke-dasharray="3 3" class="svg-static"/>

  <!-- Construction lines -->
  <line x1="150" y1="95"  x2="150" y2="16"   stroke="rgba(17,17,17,0.18)" stroke-width="0.75" stroke-dasharray="4 3" class="svg-static"/>
  <line x1="250" y1="145" x2="297" y2="121.5" stroke="rgba(17,17,17,0.18)" stroke-width="0.75" stroke-dasharray="4 3" class="svg-static"/>
  <line x1="50"  y1="145" x2="3"   y2="121.5" stroke="rgba(17,17,17,0.18)" stroke-width="0.75" stroke-dasharray="4 3" class="svg-static"/>
  <line x1="150" y1="295" x2="150" y2="390"   stroke="rgba(17,17,17,0.18)" stroke-width="0.75" stroke-dasharray="4 3" class="svg-static"/>
  <line x1="250" y1="245" x2="297" y2="268.5"  stroke="rgba(17,17,17,0.18)" stroke-width="0.75" stroke-dasharray="4 3" class="svg-static"/>
  <line x1="50"  y1="245" x2="3"   y2="268.5"  stroke="rgba(17,17,17,0.18)" stroke-width="0.75" stroke-dasharray="4 3" class="svg-static"/>

  <!-- Face fills -->
  <polygon points="150,95  250,145 150,195  50,145" fill="rgba(17,17,17,0.022)" class="svg-static"/>
  <polygon points="250,145 150,195 150,295 250,245" fill="rgba(17,17,17,0.016)" class="svg-static"/>
  <polygon points=" 50,145 150,195 150,295  50,245" fill="rgba(17,17,17,0.052)" class="svg-static"/>

  <!-- ── Cube edges (animated draw-on) ──────────────────────────────── -->
  <!-- Top face -->
  <polyline points="150,95 250,145 150,195 50,145 150,95"
    fill="none" stroke="#111111" stroke-width="1.5" stroke-linejoin="round" class="cube-top"/>
  <!-- Right vertical: B → E -->
  <line x1="250" y1="145" x2="250" y2="245" stroke="#111111" stroke-width="1.5" class="cube-vert"/>
  <!-- Left vertical: D → G -->
  <line x1=" 50" y1="145" x2=" 50" y2="245" stroke="#111111" stroke-width="1.5" class="cube-vert"/>
  <!-- Front vertical: C → F (orange — draws on last) -->
  <line x1="150" y1="195" x2="150" y2="295" stroke="#FF4F00" stroke-width="2" class="orange-edge"/>
  <!-- Bottom face visible edges -->
  <line x1="250" y1="245" x2="150" y2="295" stroke="#111111" stroke-width="1.5" class="cube-base"/>
  <line x1=" 50" y1="245" x2="150" y2="295" stroke="#111111" stroke-width="1.5" class="cube-base"/>

  <!-- Dimension / measurement lines -->
  <line x1="260" y1=" 95" x2="270" y2=" 95" stroke="rgba(17,17,17,0.28)" stroke-width="0.75" class="svg-static"/>
  <line x1="260" y1="145" x2="270" y2="145" stroke="rgba(17,17,17,0.28)" stroke-width="0.75" class="svg-static"/>
  <line x1="260" y1="195" x2="270" y2="195" stroke="rgba(17,17,17,0.28)" stroke-width="0.75" class="svg-static"/>
  <line x1="260" y1="245" x2="270" y2="245" stroke="rgba(17,17,17,0.28)" stroke-width="0.75" class="svg-static"/>
  <line x1="260" y1="295" x2="270" y2="295" stroke="rgba(17,17,17,0.28)" stroke-width="0.75" class="svg-static"/>
  <line x1="265" y1=" 95" x2="265" y2="295" stroke="rgba(17,17,17,0.12)" stroke-width="0.5"  class="svg-static"/>
  <line x1="30" y1=" 95" x2="40" y2=" 95" stroke="rgba(17,17,17,0.28)" stroke-width="0.75" class="svg-static"/>
  <line x1="30" y1="145" x2="40" y2="145" stroke="rgba(17,17,17,0.28)" stroke-width="0.75" class="svg-static"/>
  <line x1="30" y1="195" x2="40" y2="195" stroke="rgba(17,17,17,0.28)" stroke-width="0.75" class="svg-static"/>
  <line x1="30" y1="245" x2="40" y2="245" stroke="rgba(17,17,17,0.28)" stroke-width="0.75" class="svg-static"/>
  <line x1="30" y1="295" x2="40" y2="295" stroke="rgba(17,17,17,0.28)" stroke-width="0.75" class="svg-static"/>
  <line x1="35" y1=" 95" x2="35" y2="295" stroke="rgba(17,17,17,0.12)" stroke-width="0.5"  class="svg-static"/>

  <!-- Vertex dots -->
  <circle cx="150" cy=" 95" r="3"   fill="#111111" class="svg-static"/>
  <circle cx="250" cy="145" r="2.5" fill="#111111" class="svg-static"/>
  <circle cx=" 50" cy="145" r="2.5" fill="#111111" class="svg-static"/>
  <circle cx="150" cy="195" r="2.5" fill="#111111" class="svg-static"/>
  <circle cx="250" cy="245" r="2.5" fill="#111111" class="svg-static"/>
  <circle cx=" 50" cy="245" r="2.5" fill="#111111" class="svg-static"/>
  <!-- Orange accents (pop in after edge draws) -->
  <circle cx="150" cy="295" r="3.5" fill="#FF4F00" class="orange-dot"/>
  <circle cx="150" cy="245" r="2.5" fill="none" stroke="#FF4F00" stroke-width="1.25" class="orange-ring"/>

  <!-- Apex cross marker -->
  <line x1="146" y1="78" x2="154" y2="78" stroke="rgba(17,17,17,0.35)" stroke-width="1" class="svg-static"/>
  <line x1="150" y1="74" x2="150" y2="82" stroke="rgba(17,17,17,0.35)" stroke-width="1" class="svg-static"/>
</svg>
