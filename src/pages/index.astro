---
import { Image, Picture } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HeroArt from '../components/HeroArt.astro';
import {
	SITE_DESCRIPTION,
	SITE_TITLE,
	SITE_LINKEDIN_URL,
	SITE_RESUME_URL,
	SITE_X_URL,
} from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="antialiased">
		<a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-[#FF4F00] focus:px-4 focus:py-2 focus:text-white">
			Skip to content
		</a>
		<Header />
		<main id="main" class="mx-auto max-w-5xl px-6 sm:px-8">
			<section
				id="hero"
				class="relative grid min-h-[calc(100dvh-4rem)] content-center items-center gap-12 pb-28 pt-8 md:grid-cols-2 md:gap-20 xl:gap-28"
			>
				<!-- Ambient orange glow behind art -->
				<div class="hero-ambient" aria-hidden="true"></div>

				<!-- Portrait -->
				<div class="hero-in relative z-10 flex justify-center md:justify-start" style="animation-delay: 0.1s">
					<div class="w-full max-w-[20rem] aspect-[3/4] rounded-2xl md:max-w-[27rem] overflow-hidden" style="border: 1px solid rgba(0,0,0,0.08);">
						<HeroArt class="w-full h-full rounded-2xl" />
					</div>
				</div>

				<!-- Copy -->
				<div class="relative z-10 space-y-6">
					<!-- Socials + pill -->
					<div class="hero-in flex items-center gap-3" style="animation-delay: 0.15s">
						<a
							href={SITE_LINKEDIN_URL}
							class="social-icon"
							rel="noreferrer"
							target="_blank"
							aria-label="LinkedIn"
						>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
								<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
							</svg>
						</a>
						<a
							href={SITE_X_URL}
							class="social-icon"
							rel="noreferrer"
							target="_blank"
							aria-label="X (Twitter)"
						>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
								<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
							</svg>
						</a>
						<span class="h-4 w-px" style="background: rgba(0,0,0,0.12);"></span>
						<span class="inline-flex items-center rounded-full border px-4 py-2 text-[0.7rem] uppercase tracking-[0.25em]" style="border-color: rgba(0,0,0,0.2); color: var(--text-muted); height: 2.75rem;">
							Resilient Infra · Resilient Mind
						</span>
					</div>

					<h1 class="hero-in gradient-text font-display text-5xl leading-[1.06] sm:text-6xl md:text-[4.25rem] xl:text-[5rem] mt-4" style="animation-delay: 0.25s; text-wrap: balance">
						Aaron Mompié
					</h1>

					<p class="hero-in bio-quote-hero" style="animation-delay: 0.35s">
						"The same principles that keep infrastructure running keep a person standing."
					</p>

					<div class="hero-in flex flex-wrap items-center gap-4 pt-2" style="animation-delay: 0.45s">
						<a href="/blog" class="btn-primary">
							Read the Writing
						</a>
						<a href={SITE_RESUME_URL} class="btn-ghost">
							View CV
						</a>
					</div>
				</div>

				<div class="hero-in absolute inset-x-0 bottom-6 flex justify-center" style="animation-delay: 0.6s">
					<a
						href="#featured"
						class="scroll-indicator inline-flex flex-col items-center text-[0.6rem] uppercase tracking-[0.3em]"
						style="color: var(--text-muted);"
					>
						<span class="mb-3">Scroll</span>
						<span class="h-10 w-px rounded-full" style="background: rgba(0,0,0,0.12);"></span>
					</a>
				</div>
			</section>

			{posts.length > 0 && (
				<section id="featured" class="mx-auto max-w-5xl min-h-[calc(100dvh-4rem)] flex flex-col justify-center py-20" style="border-top: 1px solid var(--divider); scroll-margin-top: 4rem;">
					<div class="will-fade flex items-center justify-between gap-4">
						<h2 class="flex items-center gap-2 text-[0.7rem] font-semibold uppercase tracking-[0.3em]" style="color: var(--text-muted);">
							<span class="inline-block h-[5px] w-[5px] rounded-full flex-shrink-0" style="background: var(--orange);"></span>
							Featured writing
						</h2>
						<a href="/blog" class="link-muted text-xs font-medium">
							View all →
						</a>
					</div>

					<div class="mt-10 grid gap-6 md:grid-cols-3">
						{posts.map((post, i) => (
							<a
								href={`/blog/${post.id}/`}
								class="will-fade card-linear group flex flex-col overflow-hidden rounded-2xl p-6"
								style={`animation-delay: ${(i + 1) * 0.12}s`}
							>
								{post.data.heroImage && (
									<Picture
										width={480}
										height={260}
										src={post.data.heroImage}
										alt={post.data.title}
										formats={['avif', 'webp']}
										class="mb-5 rounded-xl object-cover opacity-90 transition group-hover:opacity-100"
										loading="lazy"
										transition:name={`post-image-${post.id}`}
									/>
								)}
								<h3 class="text-[1.05rem] font-semibold leading-snug transition">
									{post.data.title}
								</h3>
								<p class="mt-2.5 line-clamp-3 text-sm leading-relaxed">
									{post.data.description}
								</p>
								<p class="card-date">
									{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
								</p>
								<span class="card-num" aria-hidden="true">0{i + 1}</span>
							</a>
						))}
					</div>
				</section>
			)}
		</main>
		{posts.length > 0 && (
			<nav
				aria-label="Page sections"
				class="fixed right-5 top-1/2 z-50 -translate-y-1/2 flex flex-col gap-2"
			>
				<button
					data-section-pill
					class="w-[3px] rounded-full cursor-pointer"
					style="background: #111111; height: 2rem; opacity: 0.5; transition: height 0.3s, opacity 0.3s, transform 0.3s;"
					aria-label="Go to introduction"
				></button>
				<button
					data-section-pill
					class="w-[3px] rounded-full cursor-pointer"
					style="background: #111111; height: 0.875rem; opacity: 0.15; transition: height 0.3s, opacity 0.3s, transform 0.3s;"
					aria-label="Go to featured writing"
				></button>
			</nav>
		)}
		<Footer />
		<script is:inline>
			function initPage() {
				const hero = document.getElementById('hero');
				const featured = document.getElementById('featured');
				const pills = document.querySelectorAll('[data-section-pill]');
				let isJumping = false;

				// --- Fade-in for featured content ---
				if (featured) {
					const fadeEls = featured.querySelectorAll('.will-fade');
					const fadeObserver = new IntersectionObserver(
						(entries) => {
							if (entries[0].isIntersecting) {
								fadeEls.forEach((el) => el.classList.add('fade-up'));
								fadeObserver.disconnect();
							}
						},
						{ threshold: 0.15 },
					);
					fadeObserver.observe(featured);
				}

				// --- Pill active state ---
				const setActivePill = (index) => {
					pills.forEach((pill, i) => {
						const active = i === index;
						pill.style.height = active ? '2rem' : '0.875rem';
						pill.style.opacity = active ? '0.5' : '0.15';
						if (active) pill.setAttribute('data-active', '');
						else pill.removeAttribute('data-active');
					});
				};

				const pillObserver = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) setActivePill(entry.target.id === 'hero' ? 0 : 1);
						});
					},
					{ threshold: 0.4 },
				);
				if (hero) pillObserver.observe(hero);
				if (featured) pillObserver.observe(featured);

				// --- Pill click navigation ---
				pills.forEach((pill, i) => {
					pill.addEventListener('click', () => {
						const target = i === 0 ? hero : featured;
						target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
					});
				});

				// --- Jump scroll ---
				if (hero && featured) {
					window.addEventListener(
						'wheel',
						(e) => {
							if (isJumping) {
								e.preventDefault();
								return;
							}

							const scrollY = window.scrollY;
							const featuredTop = featured.offsetTop;

							if (e.deltaY > 10 && scrollY < featuredTop - 50) {
								// In hero zone — snap down to featured
								e.preventDefault();
								isJumping = true;
								featured.scrollIntoView({ behavior: 'smooth', block: 'start' });
								setTimeout(() => { isJumping = false; }, 900);
							} else if (e.deltaY < -10 && scrollY >= featuredTop - 80 && scrollY <= featuredTop + 100) {
								// At top of featured — snap back up to hero
								e.preventDefault();
								isJumping = true;
								window.scrollTo({ top: 0, behavior: 'smooth' });
								setTimeout(() => { isJumping = false; }, 900);
							}
						},
						{ passive: false },
					);
				}
			}

			document.addEventListener('astro:page-load', initPage);
		</script>
	</body>
</html>
